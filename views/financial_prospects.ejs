<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= prospect.firstName %> - Report Viewer</title>
    <style>
        body { font-family: 'Inter', sans-serif; margin: 0; display: flex; height: 100vh; background: #f1f5f9; }
        
        /* Sidebar Navigation & Data */
        .sidebar { 
            width: 400px; 
            background: white; 
            border-right: 1px solid #e2e8f0; 
            display: flex; 
            flex-direction: column;
            box-shadow: 4px 0 10px rgba(0,0,0,0.02);
        }

        .sidebar-header { padding: 24px; border-bottom: 1px solid #f1f5f9; }
        .back-nav { color: #2563eb; text-decoration: none; font-size: 0.85rem; font-weight: 600; display: block; margin-bottom: 15px; }
        
        .sidebar-content { padding: 24px; overflow-y: auto; flex-grow: 1; }
        
        h2 { margin: 0; font-size: 1.4rem; color: #0f172a; }
        .label { font-size: 0.75rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 20px; display: block; }
        .value { font-size: 1rem; color: #334155; margin: 4px 0 16px 0; }

        .ai-box { 
            background: #f8fafc; 
            border: 1px solid #e2e8f0; 
            border-radius: 8px; 
            padding: 16px; 
            font-size: 0.9rem; 
            line-height: 1.6; 
            color: #475569;
        }
        
        /* PDF Viewer Container */
        .viewer-container { flex-grow: 1; position: relative; background: #334155; }
        iframe { width: 100%; height: 100%; border: none; }
        
        .loader-overlay {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            color: white; font-weight: 500; pointer-events: none;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/reports" class="back-nav">← Pipeline View</a>
            <h2><%= prospect.firstName %> <%= prospect.lastName %></h2>
        </div>
        
        <div class="sidebar-content">
            <span class="label">Email</span>
            <div class="value"><%= prospect.email %></div>

            <span class="label">Interpretation / AI Summary</span>
            <div class="ai-box">
                <%= prospect.notes || "Analysis pending for this document..." %>
            </div>

            <span class="label">System Details</span>
            <div class="value" style="font-size: 0.8rem;">
                Object ID: <%= prospect._id %><br>
                File Status: Base64 Encoded
            </div>
        </div>
    </div>

    <div class="viewer-container">
        <div id="loader" class="loader-overlay">Loading Document...</div>
        <iframe id="pdf-frame"></iframe>
    </div>

    <script>
        // Use EJS to grab the property 'base64File'
        const rawData = "<%- prospect.base64File %>";
        const frame = document.getElementById('pdf-frame');
        const loader = document.getElementById('loader');

        if (rawData && rawData.length > 50) {
            // Logic to ensure the Data URI prefix is present
            const prefix = "data:application/pdf;base64,";
            frame.src = rawData.startsWith("data:") ? rawData : prefix + rawData;
            
            frame.onload = () => {
                loader.style.display = 'none';
            };
        } else {
            loader.innerText = "Error: File content unavailable.";
            loader.style.color = "#f87171";
        }
    </script>
</body>
</html>